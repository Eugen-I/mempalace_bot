#!/bin/bash

# Переходим в папку скрипта
cd "$(dirname "$0")"

BOT_FILE="palace_bot.py"

echo "=========================================="
echo "   MemPalace: Принудительная очистка"
echo "=========================================="

# 1. Ищем PID всех процессов, которые содержат имя файла бота
# Это покроет: python3 palace_bot.py, caffeinate ... palace_bot.py и т.д.
PIDS=$(pgrep -f "$BOT_FILE")

if [ -z "$PIDS" ]; then
    echo "✅ Активных процессов бота не найдено."
else
    echo "⚠️ Найдены процессы: $PIDS"
    echo "🛑 Завершаю..."
    
    # Убиваем процессы
    kill -9 $PIDS > /dev/null 2>&1
    
    sleep 1
    echo "✅ Все копии бота успешно удалены из памяти."
fi

echo "------------------------------------------"
echo "Теперь вы можете запустить бота заново."
echo "Это окно закроется через 3 секунды..."
sleep 3
exit