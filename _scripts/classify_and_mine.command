#!/bin/bash
# =============================================================================
# classify_and_mine.command
# Скрипт для классификации всех заметок по крыльям MemPalace.
# 
# Что делает:
#   1. Активирует виртуальное окружение (venv)
#   2. Запускает classify_and_mine.py
#   3. Ждёт нажатия Enter перед закрытием (чтобы ты успел прочитать результат)
#
# Как использовать:
#   - Двойной клик на файле → откроется Терминал и запустится скрипт
#   - Или через терминал: ./classify_and_mine.command
# =============================================================================

# Определяем путь к папке, где лежит этот скрипт (независимо от того,
# откуда его запустили)
DIR="$(cd "$(dirname "$0")" && pwd)"

# Переходим в корень проекта — там лежат config.py, services/, handlers/
BOT_DIR="$HOME/Documents/mempalace_bot"
cd "$BOT_DIR"

# Путь к Python из виртуального окружения MemPalace
# (оно создано автоматически при установке mempalace)
VENV_PYTHON="$HOME/Documents/mempalace/venv/bin/python3"

# Определяем какой Python использовать:
# 1. Если есть venv MemPalace — берём его
# 2. Если нет — используем системный Python
if [ -f "$VENV_PYTHON" ]; then
    PYTHON="$VENV_PYTHON"
else
    PYTHON="python3"
fi

echo ""
echo "=============================================="
echo "  🧠 MemPalace — Классификация по крыльям"
echo "=============================================="
echo "  Папка:       $DIR"
echo "  Python:      $PYTHON"
echo "=============================================="
echo ""

# Запускаем Python-скрипт
# Если скрипт завершится с ошибкой — покажем это в выводе
$PYTHON "$DIR/classify_and_mine.py"

# Проверяем код возврата последней команды
EXIT_CODE=$?

echo ""
if [ $EXIT_CODE -eq 0 ]; then
    echo "✅ Скрипт выполнен успешно."
else
    echo "⚠️ Скрипт завершился с ошибкой (код: $EXIT_CODE)."
    echo "   Проверь вывод выше для подробностей."
fi

echo ""
echo "=============================================="
echo "  Нажми Enter, чтобы закрыть это окно."
echo "=============================================="

# Ждём ввод пользователя, чтобы окно Terminial не закрылось сразу
# и ты успел прочитать результат
read -r
