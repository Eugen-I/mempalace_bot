#!/bin/bash
echo "======================================="
echo "       ПРОВЕРКА СЕРВЕРА OLLAMA         "
echo "======================================="

# Проверяем, запущен ли процесс ollama
if pgrep -x "ollama" > /dev/null
then
    echo "✅ Ollama уже работает."
else
    echo "🚀 Запуск Ollama..."
    # Запускаем приложение в фоновом режиме
    open -a Ollama
    
    # Ждем пару секунд, пока сервер инициализируется
    sleep 3
    echo "✅ Ollama запущена."
fi

echo "---------------------------------------"
echo "Окно закроется через 3 секунды..."
sleep 3