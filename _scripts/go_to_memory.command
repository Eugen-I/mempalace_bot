#!/bin/bash
# Переходим в папку проекта в Документах
cd "$HOME/Documents/mempalace"

# Активируем виртуальное окружение
source venv/bin/activate

# Выводим приветствие и статус, чтобы сразу видеть состояние базы
echo "======================================="
echo "   MemPalace АКТИВИРОВАН (v. 2026)     "
echo "======================================="
python3 -m mempalace status

# Оставляем терминал открытым в активном окружении
exec zsh
